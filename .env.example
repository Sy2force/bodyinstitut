# ─────────────────────────────────────────────────────────────
# Body Institut — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez vos valeurs.
# ─────────────────────────────────────────────────────────────

# ── Mot de passe admin (/admin) ───────────────────────────────
ADMIN_PASSWORD=votre_mot_de_passe

# ── Secret cookie session (32+ caractères) ───────────────────
# Générer avec : openssl rand -base64 48
AUTH_SECRET=

# ── Base de données Postgres (Neon / Supabase / Railway) ─────
# Laisser vide pour utiliser SQLite local (dev uniquement)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
