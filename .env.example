# ─────────────────────────────────────────────────────────────
# Body Institut — Environment variables
# Copy this file to `.env.local` and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Admin authentication ─────────────────────────────────────
# Default credentials for first run (CHANGE IN PRODUCTION)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=bodyinstitut

# 32+ character random string used to sign session cookies.
# Generate with:  openssl rand -base64 48
AUTH_SECRET=

# ── Booking link (CTA on success email + success screen) ─────
BOOKING_URL=https://www.planity.com

# ── Brand ────────────────────────────────────────────────────
BRAND_NAME=Body Institut
BRAND_REPLY_TO=contact@bodyinstitut.fr

# ── SMTP (optional — emails are logged to console if unset) ──
# Examples:
#   Gmail:        SMTP_HOST=smtp.gmail.com  SMTP_PORT=465
#   SendGrid:     SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey  SMTP_PASS=<your-key>
#   Mailgun:      SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Body Institut <no-reply@bodyinstitut.fr>"

# ── AI (optional — falls back to rule-based generator) ───────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
